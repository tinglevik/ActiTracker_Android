    <!-- Main Filled "Activity" Sector (315 degrees) -->
    <path
        android:pathData="M54,54 L54,24 A30,30 0 1 1 32.79,32.79 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="54"
                android:type="sweep">
                <item android:offset="0.0" android:color="#00B0FF" />
                <item android:offset="0.569" android:color="#00B0FF" />
                <item android:offset="0.625" android:color="#FFFFFF" />
                <item android:offset="0.626" android:color="#00B0FF" />
                <item android:offset="1.0" android:color="#00B0FF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Schematic Task List (Centered horizontally at x=54) -->
    <!-- Calculation for Horizontal Centering:
         Dot diameter: 7 units (Radius 3.5)
         Space between Dot and Line: 4 units
         Line length: 22 units
         Total width = 7 + 4 + 22 = 33 units
         To center it: Start X = 54 - (33 / 2) = 54 - 16.5 = 37.5
         Dot Center X = 37.5 + 3.5 = 41
         Line Start X = 37.5 + 7 + 4 = 48.5
         Line End X = 48.5 + 22 = 70.5
    -->

    <!-- Dots (3 circles) in Black for better contrast -->
    <path
        android:fillColor="#1E2A38"
        android:pathData="M41,44m-3.5,0a3.5,3.5 0 1,1 7,0a3.5,3.5 0 1,1 -7,0
                          M41,54m-3.5,0a3.5,3.5 0 1,1 7,0a3.5,3.5 0 1,1 -7,0
                          M41,64m-3.5,0a3.5,3.5 0 1,1 7,0a3.5,3.5 0 1,1 -7,0" />

    <!-- Horizontal Lines (3 lines) in Black -->
    <path
        android:strokeColor="#1E2A38"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:pathData="M48.5,44 L70.5,44
                          M48.5,54 L70.5,54
                          M48.5,64 L70.5,64" />

</vector>